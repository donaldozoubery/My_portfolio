# Configuration d'environnement pour le portfolio ultra-moderne
# Copiez ce fichier vers .env et remplissez les valeurs

# ========================================
# CONFIGURATION DJANGO
# ========================================
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ========================================
# BASE DE DONNÉES
# ========================================
# Pour le développement local (SQLite)
# DATABASE_URL=sqlite:///db.sqlite3

# Pour la production (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/portfolio_db

# ========================================
# CLOUDINARY (Gestion des médias)
# ========================================
CLOUD_NAME=your-cloudinary-name
CLOUD_API_KEY=your-cloudinary-api-key
CLOUD_API_SECRET=your-cloudinary-api-secret

# ========================================
# EMAIL CONFIGURATION
# ========================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ========================================
# RECAPTCHA (Sécurité des formulaires)
# ========================================
RECAPTCHA_PUBLIC_KEY=your-recaptcha-public-key
RECAPTCHA_PRIVATE_KEY=your-recaptcha-private-key

# ========================================
# ANALYTICS (Optionnel)
# ========================================
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# ========================================
# REDIS (Cache - Optionnel)
# ========================================
REDIS_URL=redis://localhost:6379/0

# ========================================
# CONFIGURATION DE PRODUCTION
# ========================================
# Définir sur False en production
DEBUG=False

# URL de votre domaine en production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Configuration SSL
SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=('HTTP_X_FORWARDED_PROTO', 'https')
